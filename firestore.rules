rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Layer 1: The Hardcoded Email Whitelist
    function isWhitelistedEmail() {
      return isSignedIn() && 
             request.auth.token.email in [
               "dmoritz10@gmail.com", 
               "christinamoritz@gmail.com"
             ];
    }

    // Layer 2: The Firestore Document check (UID must be the Doc ID)
    function isRegisteredUser() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isFullyAuthorized() {
      return isWhitelistedEmail() && isRegisteredUser();
    }

    // Check if the current user has the 'admin' flag set to true in their doc
    function isAdmin() {
      return isFullyAuthorized() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    // Check specifically for Christina's email
    function isPartner() {
      return isFullyAuthorized() && 
             request.auth.token.email == "christinamoritz@gmail.com";
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    // Read-only for the app. All management happens in the Firebase Console.
    match /users/{userId} {
      allow read: if isWhitelistedEmail() && request.auth.uid == userId;
      allow write: if false; 
    }

    // 2. Sensitive collections
    // All can read/edit, but only Admin can delete.
    match /categories/{category} {
      allow read, create, update: if isFullyAuthorized();
      allow delete: if isAdmin();
    }

    // 3. read/edit AND delete
    match /accounts/{account} {
      allow read, create, update: if isFullyAuthorized();
      allow delete: if isAdmin() || isPartner();
    }
    
    // 4. Global Fallback
    // For any other collections default to Admin-only deletion for safety.
    match /{collection}/{document} {
      allow read, create, update: if isFullyAuthorized();
      allow delete: if isAdmin();
    }
  }
}